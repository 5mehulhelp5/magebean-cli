{
    "control": "MB-C04",
    "title": "HTTPS & TLS Enforcement",
    "rules": [
        {
            "id": "MB-R026",
            "title": "Force HTTPS in admin and storefront",
            "control": "MB-C04",
            "severity": "high",
            "op": "any",
            "checks": [
                {
                    "name": "php_array_eq",
                    "args": {
                        "file": "app/etc/env.php",
                        "path": "system.default.web.secure.use_in_adminhtml",
                        "equals": 1
                    }
                },
                {
                    "name": "php_array_eq",
                    "args": {
                        "file": "app/etc/env.php",
                        "path": "system.default.web.secure.use_in_frontend",
                        "equals": 1
                    }
                },
                {
                    "name": "http_force_https_redirect",
                    "args": {
                        "timeout_ms": 8000
                    }
                }
            ],
            "messages": {
                "pass": "HTTPS is enforced for both admin and storefront areas.",
                "fail": "HTTPS is not enforced in admin or storefront. Enable secure URLs in env.php."
            }
        },
        {
            "id": "MB-R027",
            "title": "HSTS header is set",
            "control": "MB-C04",
            "severity": "medium",
            "op": "any",
            "checks": [
                {
                    "name": "http_has_hsts",
                    "args": {
                        "min_max_age": 15552000,
                        "timeout_ms": 8000
                    }
                }
            ],
            "messages": {
                "pass": "HSTS (Strict-Transport-Security) header is configured.",
                "fail": "HSTS header is missing. Add Strict-Transport-Security to enforce HTTPS on clients."
            }
        },
        {
            "id": "MB-R028",
            "title": "TLS protocols >= 1.2",
            "control": "MB-C04",
            "severity": "high",
            "op": "any",
            "checks": [
                {
                    "name": "http_tls_min_version",
                    "args": {
                        "timeout_ms": 8000
                    }
                }
            ],
            "messages": {
                "pass": "TLS is configured to use version 1.2 or higher.",
                "fail": "TLS configuration allows outdated protocols. Restrict to TLS 1.2+."
            }
        },
        {
            "id": "MB-R029",
            "title": "No mixed content (http://) in templates/assets",
            "control": "MB-C04",
            "severity": "medium",
            "op": "any",
            "checks": [
                {
                    "name": "code_grep",
                    "args": {
                        "paths": [
                            "app/design",
                            "app"
                        ],
                        "include_ext": [
                            "phtml",
                            "js",
                            "html",
                            "xml",
                            "css",
                            "less"
                        ],
                        "must_not_match": [
                            "(src|href|url)\\s*=\\s*['\\\"]http:\\\\\\/\\\\\\/[^'\\\"\\\\]+['\\\"]"
                        ],
                        "max_results": 50
                    }
                },
                {
                    "name": "http_no_mixed_content",
                    "args": {
                        "timeout_ms": 8000
                    }
                }
            ],
            "messages": {
                "pass": "No insecure http:// references detected in templates or assets.",
                "fail": "Mixed content detected. Replace http:// references with https://."
            }
        },
        {
            "id": "MB-R030",
            "title": "Secure cookies: Secure + HttpOnly enabled",
            "control": "MB-C04",
            "severity": "high",
            "op": "all",
            "checks": [
                {
                    "name": "php_array_eq",
                    "args": {
                        "file": "app/etc/env.php",
                        "path": "session.cookie.secure",
                        "equals": 1
                    }
                },
                {
                    "name": "php_array_eq",
                    "args": {
                        "file": "app/etc/env.php",
                        "path": "session.cookie.httponly",
                        "equals": 1
                    }
                },
                {
                    "name": "http_cookie_flags",
                    "args": {
                        "timeout_ms": 8000
                    }
                }
            ],
            "messages": {
                "pass": "Session cookies are configured with Secure and HttpOnly flags.",
                "fail": "Cookies lack Secure or HttpOnly flags. Enable them to protect against theft and XSS."
            }
        },
        {
            "id": "MB-R089",
            "title": "Checkout Content Security Policy enforced",
            "control": "MB-C04",
            "severity": "high",
            "op": "any",
            "checks": [
                {
                    "name": "http_csp_present_min",
                    "args": {
                        "paths": [
                            "/checkout/",
                            "/checkout"
                        ],
                        "timeout_ms": 8000
                    }
                },
                {
                    "name": "code_grep",
                    "args": {
                        "paths": [
                            "app/code",
                            "app/etc",
                            "app/design"
                        ],
                        "include_ext": [
                            "xml",
                            "php",
                            "phtml"
                        ],
                        "must_match": [
                            "(?i)(content-security-policy|csp_whitelist|script-src|frame-src|connect-src|report-uri|report-to)"
                        ],
                        "max_results": 20
                    }
                }
            ],
            "messages": {
                "pass": "Checkout CSP signals are present.",
                "fail": "Checkout CSP could not be verified. Configure strict payment-page CSP and reporting directives."
            }
        },
        {
            "id": "MB-R096",
            "title": "Security headers baseline enforced",
            "control": "MB-C04",
            "severity": "medium",
            "op": "all",
            "checks": [
                {
                    "name": "http_clickjacking_protection",
                    "args": {
                        "timeout_ms": 8000
                    }
                },
                {
                    "name": "http_csp_not_overly_permissive",
                    "args": {
                        "timeout_ms": 8000
                    }
                },
                {
                    "name": "http_header_in",
                    "args": {
                        "header": "x-content-type-options",
                        "allowed": [
                            "nosniff"
                        ],
                        "timeout_ms": 8000
                    }
                }
            ],
            "messages": {
                "pass": "Baseline browser security headers are present.",
                "fail": "Security header baseline is incomplete. Configure CSP/frame protection and X-Content-Type-Options."
            }
        }
    ]
}
