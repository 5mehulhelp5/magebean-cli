{
    "control": "MB-C04",
    "title": "HTTPS & TLS Enforcement",
    "rules": [
        {
            "id": "MB-R026",
            "title": "Force HTTPS in admin and storefront",
            "control": "MB-C04",
            "severity": "high",
            "op": "all",
            "checks": [
                {
                    "name": "magento_https_enforced",
                    "args": {
                        "files": [
                            "app/etc/config.php",
                            "app/etc/env.php"
                        ],
                        "timeout_ms": 8000
                    }
                }
            ],
            "messages": {
                "pass": "HTTPS is enforced for both admin and storefront areas.",
                "fail": "HTTPS is not enforced in admin or storefront. Enable secure URLs in env.php."
            }
        },
        {
            "id": "MB-R027",
            "title": "HSTS header is set",
            "control": "MB-C04",
            "severity": "medium",
            "op": "any",
            "checks": [
                {
                    "name": "http_has_hsts",
                    "args": {
                        "min_max_age": 15552000,
                        "timeout_ms": 8000
                    }
                },
                {
                    "name": "webserver_hsts_config",
                    "args": {
                        "files": [
                            "nginx.conf",
                            "pub/.htaccess",
                            ".htaccess"
                        ],
                        "min_max_age": 15552000
                    }
                }
            ],
            "messages": {
                "pass": "HSTS (Strict-Transport-Security) header is configured.",
                "fail": "HSTS header is missing. Add Strict-Transport-Security to enforce HTTPS on clients."
            }
        },
        {
            "id": "MB-R028",
            "title": "TLS protocols >= 1.2",
            "control": "MB-C04",
            "severity": "high",
            "op": "any",
            "checks": [
                {
                    "name": "http_tls_min_version",
                    "args": {
                        "timeout_ms": 8000
                    }
                }
            ],
            "messages": {
                "pass": "TLS is configured to use version 1.2 or higher.",
                "fail": "TLS configuration allows outdated protocols. Restrict to TLS 1.2+."
            }
        },
        {
            "id": "MB-R029",
            "title": "No mixed content (http://) in templates/assets",
            "control": "MB-C04",
            "severity": "medium",
            "op": "all",
            "checks": [
                {
                    "name": "code_no_mixed_content",
                    "args": {
                        "paths": [
                            "app"
                        ],
                        "include_ext": [
                            "phtml",
                            "js",
                            "html",
                            "xml",
                            "css",
                            "less"
                        ],
                        "max_results": 50
                    }
                },
                {
                    "name": "http_no_mixed_content",
                    "args": {
                        "paths": [
                            "/"
                        ],
                        "timeout_ms": 8000
                    }
                }
            ],
            "messages": {
                "pass": "No insecure http:// references detected in templates or assets.",
                "fail": "Mixed content detected. Replace http:// references with https://."
            }
        },
        {
            "id": "MB-R030",
            "title": "Secure cookies: Secure + HttpOnly enabled",
            "control": "MB-C04",
            "severity": "high",
            "op": "all",
            "checks": [
                {
                    "name": "magento_cookie_flags_secure",
                    "args": {
                        "files": [
                            "app/etc/config.php",
                            "app/etc/env.php"
                        ],
                        "allowed_samesite": [
                            "lax",
                            "strict"
                        ]
                    }
                },
                {
                    "name": "http_cookie_flags",
                    "args": {
                        "paths": [
                            "/",
                            "/customer/account/login",
                            "/checkout/cart"
                        ],
                        "timeout_ms": 8000
                    }
                }
            ],
            "messages": {
                "pass": "Session cookies are configured with Secure, HttpOnly, and SameSite flags.",
                "fail": "Cookies lack Secure, HttpOnly, or SameSite flags. Enable them to protect against theft, XSS, and CSRF."
            }
        },
        {
            "id": "MB-R089",
            "title": "Checkout Content Security Policy enforced",
            "control": "MB-C04",
            "severity": "high",
            "op": "all",
            "checks": [
                {
                    "name": "code_checkout_csp_enforced",
                    "args": {
                        "paths": [
                            "app/code",
                            "app/etc",
                            "app/design",
                            "pub/.htaccess",
                            ".htaccess",
                            "nginx.conf"
                        ],
                        "include_ext": [
                            "xml",
                            "php",
                            "phtml",
                            "html",
                            "conf",
                            "htaccess"
                        ],
                        "required_directives": [
                            "script-src",
                            "connect-src",
                            "frame-src",
                            "form-action"
                        ],
                        "require_reporting": true
                    }
                }
            ],
            "messages": {
                "pass": "Checkout CSP includes payment-page script, connection, frame, form-action, and reporting controls."
            }
        },
        {
            "id": "MB-R096",
            "title": "Security headers baseline enforced",
            "control": "MB-C04",
            "severity": "medium",
            "op": "all",
            "checks": [
                {
                    "name": "http_clickjacking_protection",
                    "args": {
                        "timeout_ms": 8000
                    }
                },
                {
                    "name": "http_csp_not_overly_permissive",
                    "args": {
                        "timeout_ms": 8000
                    }
                },
                {
                    "name": "http_header_in",
                    "args": {
                        "header": "x-content-type-options",
                        "allowed": [
                            "nosniff"
                        ],
                        "timeout_ms": 8000
                    }
                }
            ],
            "messages": {
                "pass": "Baseline browser security headers are present.",
                "fail": "Security header baseline is incomplete. Configure CSP/frame protection and X-Content-Type-Options."
            }
        }
    ]
}
