{
  "control": "MB-C10",
  "title": "Abandoned Extensions Removal",
  "rules": [
    {
      "id": "MB-R061",
      "title": "No packages marked 'abandoned' on Packagist",
      "control": "MB-C10",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "composer_abandoned_api",
          "args": {
            "lock_file": "composer.lock",
            "status_endpoint": "https://api.magebean.com/v1/packages/status",
            "timeout_ms": 10000,
            "allow_private_http_fallback": true
          }
        }
      ],
      "messages": {
        "pass": "No installed packages are marked as abandoned in the Packagist snapshot."
      }
    },
    {
      "id": "MB-R062",
      "title": "No packages without release in > 24 months",
      "control": "MB-C10",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "composer_release_recency_api",
          "args": {
            "lock_file": "composer.lock",
            "status_endpoint": "https://api.magebean.com/v1/packages/status",
            "timeout_ms": 10000,
            "allow_private_http_fallback": true,
            "months": 24
          }
        }
      ],
      "messages": {
        "pass": "Packagist-tracked packages have had a release within the last 24 months."
      }
    },
    {
      "id": "MB-R063",
      "title": "No packages from archived or disabled repositories",
      "control": "MB-C10",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "composer_repo_archived_api",
          "args": {
            "lock_file": "composer.lock",
            "status_endpoint": "https://api.magebean.com/v1/packages/status",
            "timeout_ms": 10000,
            "allow_private_http_fallback": true
          }
        }
      ],
      "messages": {
        "pass": "No installed packages come from archived or disabled repositories.",
        "fail": "Packages from archived or disabled repositories detected. Migrate to active upstreams."
      }
    },
    {
      "id": "MB-R064",
      "title": "No risky forks replacing upstream libs",
      "control": "MB-C10",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "composer_risky_fork_api",
          "args": {
            "lock_file": "composer.lock",
            "status_endpoint": "https://api.magebean.com/v1/packages/status",
            "timeout_ms": 10000,
            "allow_private_http_fallback": true
          }
        }
      ],
      "messages": {
        "pass": "No risky forks detected replacing upstream libraries.",
        "fail": "Risky forks detected. Prefer official upstreams or vetted, actively maintained forks."
      }
    }
  ]
}
