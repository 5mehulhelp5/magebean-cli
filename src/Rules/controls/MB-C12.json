{
  "control": "MB-C12",
  "title": "Third-party Config Security",
  "rules": [
    {
      "id": "MB-R072",
      "title": "No secrets in VCS (working tree or git history)",
      "control": "MB-C12",
      "severity": "critical",
      "op": "all",
      "checks": [
        {
          "name": "webroot_hygiene",
          "args": {
            "webroot": ".",
            "forbidden": [
              ".env",
              ".env.local",
              "*.pem",
              "*.key"
            ]
          }
        },
        {
          "name": "git_history_scan",
          "args": {
            "paths": [
              "app",
              "env",
              "pub"
            ],
            "patterns": [
              "AKIA[0-9A-Z]{16}",
              "ASIA[0-9A-Z]{16}",
              "AIza[0-9A-Za-z\\-_]{35}",
              "-----BEGIN( RSA)? PRIVATE KEY-----",
              "xox[baprs]-[0-9A-Za-z\\-]{10,48}",
              "sk_live_[0-9a-zA-Z]{24,}"
            ],
            "max_results": 20
          }
        }
      ],
      "messages": {
        "pass": "No secrets detected in the working tree or Git history.",
        "fail": "Secrets detected in files or Git history. Remove, rotate keys, and purge history with a secure rewrite."
      }
    },
    {
      "id": "MB-R073",
      "title": "HTTPS-only endpoints configured",
      "control": "MB-C12",
      "severity": "high",
      "op": "any",
      "checks": [
        {
          "name": "text_grep",
          "args": {
            "file": "app/etc/env.php",
            "must_not_match": [
              "http://"
            ]
          }
        },
        {
          "name": "code_grep",
          "args": {
            "paths": [
              "app"
            ],
            "include_ext": [
              "php",
              "phtml",
              "js",
              "html",
              "xml"
            ],
            "must_not_match": [
              "http://[^\\s\"'>]+"
            ]
          }
        }
      ],
      "messages": {
        "pass": "All configured endpoints use HTTPS (no http:// references).",
        "fail": "Insecure http:// endpoint references found. Switch to HTTPS."
      }
    },
    {
      "id": "MB-R074",
      "title": "Debug/verbose off for third-party integrations",
      "control": "MB-C12",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "php_array_eq",
          "args": {
            "file": "app/etc/env.php",
            "path": "system.default.dev/debug/debug_logging",
            "equals": 0
          }
        }
      ],
      "messages": {
        "pass": "Third-party debug/verbose logging is disabled.",
        "fail": "Third-party debug/verbose logging is enabled. Disable debug_logging in env.php."
      }
    },
    {
      "id": "MB-R075",
      "title": "Webhook signature validation present",
      "control": "MB-C12",
      "severity": "high",
      "op": "any",
      "checks": [
        {
          "name": "code_grep",
          "args": {
            "paths": [
              "app",
              "routes"
            ],
            "include_ext": [
              "php"
            ],
            "must_not_match": [
              "(?:Route::\\s*(?:post|put|patch|any)\\s*\\(\\s*['\"][^'\"]*webhook)",
              "WebhookController",
              "handleWebhook\\s*\\("
            ]
          }
        },
        {
          "name": "code_grep",
          "args": {
            "paths": [
              "app",
              "vendor"
            ],
            "include_ext": [
              "php"
            ],
            "must_match": [
              "(\\$_SERVER\\[['\"]HTTP_[A-Z0-9_]*SIGNATURE['\"]\\]|->header\\s*\\(\\s*['\"][Xx][-_]?[A-Za-z0-9-]*[Ss]ignature['\"]\\s*\\)|getHeader\\s*\\(\\s*['\"][Xx][^'\"]*[Ss]ignature['\"]\\s*\\))",
              "(hash_hmac\\s*\\(|hash_equals\\s*\\(|openssl_verify\\s*\\(|sodium_crypto_sign_verify_detached\\s*\\()"
            ]
          }
        }
      ],
      "messages": {
        "pass": "Webhook handlers validate signatures (provider header + secure verification), or no webhook endpoints are present.",
        "fail": "Webhook signature validation not detected. Verify MAC/signature from provider headers with timing-safe compare."
      }
    },
    {
      "id": "MB-R076",
      "title": "Outbound connections restricted by allow-list",
      "control": "MB-C12",
      "severity": "medium",
      "op": "any",
      "checks": [
        {
          "name": "system_egress_restricted",
          "args": {}
        },
        {
          "name": "code_grep",
          "args": {
            "paths": [
              "app",
              "vendor"
            ],
            "include_ext": [
              "php"
            ],
            "must_match": [
              "(?is)(allowlist|whitelist|allowed[_-]?(hosts|domains)|trusted[_-]?hosts?|allowedOrigins|originAllow(?:list)?)"
            ]
          }
        },
        {
          "name": "code_grep",
          "args": {
            "paths": [
              "app",
              "vendor"
            ],
            "include_ext": [
              "php"
            ],
            "must_match": [
              "CURLOPT_(CONNECTTIMEOUT|TIMEOUT)(?:_MS)?",
              "->set(?:Connect)?Timeout\\s*\\(",
              "->setOptions\\s*\\(\\s*\\[.*\\b(connect_)?timeout\\b\\s*=>",
              "curl_setopt_array\\s*\\(.*CURLOPT_(CONNECTTIMEOUT|TIMEOUT)(?:_MS)?",
              "->request\\s*\\([^\\)]*\\[.*\\b(connect_)?timeout\\b\\s*=>",
              "stream_context_create\\s*\\(\\s*\\[.*\\btimeout\\b\\s*=>",
              "\\bRequestOptions::(CONNECT_TIMEOUT|TIMEOUT)\\b"
            ],
            "regex_flags": "is"
          }
        }
      ],
      "messages": {
        "pass": "Outbound connections are enforced by network policy (egress firewall) or code-level allowlist and timeouts.",
        "fail": "No egress restriction detected. Enforce outbound allow-list at firewall (UFW/IPTABLES) or in code (allow-listed domains + HTTP timeouts)."
      }
    },
    {
      "id": "MB-R077",
      "title": "PII minimization for third-party flows",
      "control": "MB-C12",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_grep",
          "args": {
            "paths": [
              "app"
            ],
            "include_ext": [
              "php"
            ],
            "must_not_match": [
              "full_card",
              "cvv",
              "ssn",
              "passport_number"
            ]
          }
        }
      ],
      "messages": {
        "pass": "No direct handling of sensitive PII (e.g., full card, CVV, SSN, passport).",
        "fail": "Sensitive PII handling detected. Remove or tokenize via a PCI-compliant provider."
      }
    },
    {
      "id": "MB-R078",
      "title": "Strong TLS ciphers on upstream gateways",
      "control": "MB-C12",
      "severity": "medium",
      "op": "any",
      "checks": [
        {
          "name": "nginx_directive",
          "args": {
            "file": "nginx.conf",
            "directive": "ssl_ciphers\\s+.*(TLSv1\\.2|TLSv1\\.3|ECDHE)\\b",
            "expects_regex": true
          }
        },
        {
          "name": "apache_htaccess_directive",
          "args": {
            "file": "pub/.htaccess",
            "directive": "SSLCipherSuite\\s+",
            "expects_regex": true
          }
        }
      ],
      "messages": {
        "pass": "Web server enforces strong TLS ciphers (TLS 1.2/1.3, ECDHE).",
        "fail": "Weak or unspecified TLS ciphers. Configure strong cipher suites on the web server."
      }
    },
    {
      "id": "MB-R079",
      "title": "API keys stored in env.php (not in DB/plain code)",
      "control": "MB-C12",
      "severity": "high",
      "op": "any",
      "checks": [
        {
          "name": "php_array_key_search",
          "args": {
            "file": "app/etc/env.php",
            "key_regex": "(api_)?key|secret|token",
            "min_found": 1
          }
        },
        {
          "name": "code_grep",
          "args": {
            "paths": [
              "app"
            ],
            "include_ext": [
              "php",
              "phtml",
              "xml"
            ],
            "must_not_match": [
              "(?i)INSERT\\s+INTO\\s+.*\\bcore_config_data\\b.*\\b(path|value)\\b.*(api[_-]?key|secret|token)",
              "(?i)UPDATE\\s+\\bcore_config_data\\b.*\\b(path|value)\\b.*(api[_-]?key|secret|token)",
              "(?i)INSERT\\s+INTO\\s+.*(api[_-]?key|secret|token)",
              "(?i)update\\s+.*(api[_-]?key|secret|token)",
              "(?i)setData\\(\\s*['\\\"](?:payment\\/[^'\\\"]+\\/)?(api[_-]?key|secret|token)",
              "(?i)setValue\\(\\s*['\\\"](?:payment\\/[^'\\\"]+\\/)?(api[_-]?key|secret|token)",
              "(?i)save\\(\\)\\s*;\\s*\\/\\/.*(api[_-]?key|secret|token).*",
              "(?i)Config\\s*\\(.*(api[_-]?key|secret|token).*\\)"
            ]
          }
        }
      ],
      "messages": {
        "pass": "API credentials are stored in env.php, not embedded in code or the DB.",
        "fail": "API keys found in code or DB paths. Move secrets to env.php and rotate compromised keys."
      }
    },
    {
      "id": "MB-R080",
      "title": "Third-party logging sanitized (mask/redact)",
      "control": "MB-C12",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "code_grep",
          "args": {
            "paths": [
              "app"
            ],
            "include_ext": [
              "php"
            ],
            "must_match": [
              "mask|redact|sanitize|filter"
            ]
          }
        }
      ],
      "messages": {
        "pass": "Third-party logs apply masking/redaction for sensitive fields.",
        "fail": "Logs are not sanitized. Add masking or redaction for tokens, emails, and identifiers."
      }
    },
    {
      "id": "MB-R081",
      "title": "SaaS integrations scoped by ACL (least privilege/IP allowlist)",
      "control": "MB-C12",
      "severity": "low",
      "op": "any",
      "checks": [
        {
          "name": "text_grep",
          "args": {
            "file": "SECURITY.md",
            "must_match": [
              "least privilege|scope",
              "IP allowlist|CIDR"
            ]
          }
        },
        {
          "name": "text_grep",
          "args": {
            "file": "docs/integrations.md",
            "must_match": [
              "least privilege|scope",
              "IP allowlist|CIDR"
            ]
          }
        }
      ],
      "messages": {
        "pass": "Integration docs mention least-privilege scopes and optional IP allowlisting.",
        "fail": "No ACL/scoping guidance found. Document least-privilege permissions and IP allowlists."
      }
    },
    {
      "id": "MB-R082",
      "title": "No PAN, CVV, or track data stored in database",
      "control": "MB-C12",
      "severity": "critical",
      "op": "all",
      "checks": [
        {
          "name": "code_grep",
          "args": {
            "paths": [
              "app",
              "app/code"
            ],
            "include_ext": [
              "php",
              "xml",
              "sql",
              "json"
            ],
            "must_not_match": [
              "(?i)\\b(?:cc_number|card_number|credit_card_number|primary_account_number|pan|cvv|cvc|track1|track2|magnetic_stripe)\\b",
              "(?i)(?:CREATE|ALTER)\\s+TABLE[^;]+\\b(?:cc|card|payment)[^;]+\\b(?:number|cvv|cvc|track|pan)\\b",
              "(?i)(?:INSERT|UPDATE)\\s+[^;]+\\b(?:cc_number|card_number|cvv|cvc|track1|track2|pan)\\b"
            ],
            "max_results": 50
          }
        }
      ],
      "messages": {
        "pass": "No database schema or code patterns indicating stored raw cardholder data were detected.",
        "fail": "Potential raw cardholder data storage detected. Remove PAN/CVV/track storage and use tokenized payment references."
      }
    },
    {
      "id": "MB-R085",
      "title": "Payment method scope detection",
      "control": "MB-C12",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_grep",
          "args": {
            "paths": [
              "app",
              "app/design"
            ],
            "include_ext": [
              "php",
              "phtml",
              "js",
              "xml"
            ],
            "must_not_match": [
              "(?i)\\b(?:direct.?post|raw.?card|card[_-]?number|cc[_-]?number|cvv|cvc)\\b",
              "(?i)<field[^>]+id\\s*=\\s*['\\\"](?:cc_number|card_number|cvv|cvc)['\\\"]"
            ],
            "max_results": 50
          }
        }
      ],
      "messages": {
        "pass": "No obvious direct raw-card payment scope patterns detected.",
        "fail": "Payment method patterns may expand PCI scope. Prefer hosted redirect, hosted fields, or tokenized provider SDKs."
      }
    },
    {
      "id": "MB-R087",
      "title": "Payment page script inventory maintained",
      "control": "MB-C12",
      "severity": "high",
      "op": "any",
      "checks": [
        {
          "name": "fs_exists",
          "args": {
            "path": ".magebean/payment-scripts.json"
          }
        },
        {
          "name": "fs_exists",
          "args": {
            "path": "docs/payment-script-inventory.md"
          }
        },
        {
          "name": "code_grep",
          "args": {
            "paths": [
              "app/design",
              "app/code"
            ],
            "include_ext": [
              "xml",
              "phtml",
              "js"
            ],
            "must_match": [
              "(?i)(checkout|payment).{0,120}<script|<script.{0,120}(checkout|payment)|csp_whitelist"
            ],
            "max_results": 20
          }
        }
      ],
      "messages": {
        "pass": "Payment page script inventory or script source signals are present.",
        "fail": "No payment page script inventory found. Maintain an approved inventory of scripts loaded on checkout/payment pages."
      }
    },
    {
      "id": "MB-R088",
      "title": "Payment page script allowlist and integrity controls",
      "control": "MB-C12",
      "severity": "high",
      "op": "any",
      "checks": [
        {
          "name": "code_grep",
          "args": {
            "paths": [
              "app",
              "app/design"
            ],
            "include_ext": [
              "xml",
              "phtml",
              "html",
              "js"
            ],
            "must_match": [
              "(?i)(integrity=|sha256-|nonce|csp_whitelist|script-src|report-uri|report-to)"
            ],
            "max_results": 20
          }
        },
        {
          "name": "fs_exists",
          "args": {
            "path": ".magebean/payment-script-integrity.json"
          }
        }
      ],
      "messages": {
        "pass": "Payment page script allowlist or integrity controls are present.",
        "fail": "No script allowlist or integrity controls found for payment pages. Add CSP allowlisting, SRI/hashes, nonces, or monitoring evidence."
      }
    },
    {
      "id": "MB-R092",
      "title": "Payment webhook endpoint authentication hardening",
      "control": "MB-C12",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_grep",
          "args": {
            "paths": [
              "app/code"
            ],
            "include_ext": [
              "php",
              "xml"
            ],
            "must_not_match": [
              "(?is)class\\s+\\w+.*?(?:Webhook|Callback|Ipn|Notification).*?function\\s+execute\\s*\\([^)]*\\)\\s*\\{(?:(?!hash_hmac|Signature|signature|webhook_secret|verify|validate|isValid|idempotency).){0,1800}\\b(?:invoice|capture|refund|payment|order|transaction)\\b",
              "(?is)<route\\b[^>]*url\\s*=\\s*['\\\"][^'\\\"]*(?:webhook|callback|ipn|notification)[^'\\\"]*['\\\"][^>]*>\\s*<service[^>]+resource\\s*=\\s*['\\\"]anonymous['\\\"]"
            ],
            "max_results": 50
          }
        }
      ],
      "messages": {
        "pass": "No unauthenticated payment webhook endpoint patterns detected.",
        "fail": "Potential unauthenticated payment webhook/callback detected. Validate signatures, timestamps, replay windows, and idempotency."
      }
    }
  ]
}
