{
  "control": "MB-C12",
  "title": "Third-party Config Security",
  "rules": [
    {
      "id": "MB-R072",
      "title": "No secrets in VCS (working tree or git history)",
      "control": "MB-C12",
      "severity": "critical",
      "op": "all",
      "checks": [
        {
          "name": "git_history_scan",
          "args": {
            "paths": ["."],
            "exclude_dirs": [
              ".git",
              "vendor",
              "var",
              "generated",
              "node_modules",
              "pub/media",
              "pub/static",
              "pub/cache"
            ],
            "patterns": [
              "AKIA[0-9A-Z]{16}",
              "ASIA[0-9A-Z]{16}",
              "AIza[0-9A-Za-z\\-_]{35}",
              "-----BEGIN [A-Z0-9 ]*PRIVATE KEY-----",
              "xox[baprs]-[0-9A-Za-z\\-]{10,48}",
              "sk_live_[0-9a-zA-Z]{24,}",
              "gh[pousr]_[0-9A-Za-z]{36,255}",
              "(api[_-]?key|client[_-]?secret|access[_-]?token|password)[[:space:]]*[\"']?[[:space:]]*(=>|=|:)[[:space:]]*[\"'][A-Za-z0-9_./+=-]{16,}[\"']"
            ],
            "max_results": 200,
            "max_file_bytes": 1048576
          }
        }
      ],
      "messages": {
        "pass": "No secrets detected in the working tree or Git history."
      }
    },
    {
      "id": "MB-R073",
      "title": "HTTPS-only endpoints configured",
      "control": "MB-C12",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_https_endpoints",
          "args": {
            "paths": [
              "app/etc",
              "app/code",
              "app/design"
            ],
            "include_ext": [
              "php",
              "phtml",
              "xml",
              "json",
              "yaml",
              "yml",
              "ini",
              "js",
              "html",
              "css"
            ],
            "required_files": [
              "app/etc/env.php"
            ],
            "max_results": 200
          }
        }
      ],
      "messages": {
        "pass": "All detected configured endpoints use HTTPS."
      }
    },
    {
      "id": "MB-R074",
      "title": "Debug/verbose off for third-party integrations",
      "control": "MB-C12",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "php_third_party_debug_disabled",
          "args": {
            "files": [
              "app/etc/env.php",
              "app/etc/config.php"
            ]
          }
        }
      ],
      "messages": {
        "pass": "Third-party debug/verbose logging is disabled."
      }
    },
    {
      "id": "MB-R075",
      "title": "Webhook signature validation present",
      "control": "MB-C12",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_webhook_signature_validation",
          "args": {
            "paths": [
              "app/code",
              "app/etc",
              "routes"
            ],
            "include_ext": [
              "php",
              "xml"
            ],
            "max_results": 100
          }
        }
      ],
      "messages": {
        "pass": "Webhook handlers validate provider signatures, or no webhook endpoints are present."
      }
    },
    {
      "id": "MB-R076",
      "title": "Outbound connections restricted by allow-list",
      "control": "MB-C12",
      "severity": "medium",
      "op": "any",
      "checks": [
        {
          "name": "system_egress_restricted",
          "args": {}
        },
        {
          "name": "code_outbound_egress_controls",
          "args": {
            "paths": [
              "app/code",
              "app/etc"
            ],
            "include_ext": [
              "php"
            ],
            "max_results": 100
          }
        }
      ],
      "messages": {
        "pass": "Outbound connections are enforced by network policy or each app-level outbound sink has allowlist and timeout controls.",
        "fail": "No egress restriction detected. Enforce outbound allow-list at firewall or add code-level host allowlists and HTTP timeouts."
      }
    },
    {
      "id": "MB-R077",
      "title": "PII minimization for third-party flows",
      "control": "MB-C12",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_pii_minimization",
          "args": {
            "paths": [
              "app/code"
            ],
            "include_ext": [
              "php"
            ],
            "max_results": 100
          }
        }
      ],
      "messages": {
        "pass": "Third-party flows avoid raw sensitive PII or use tokenized/minimized payloads."
      }
    },
    {
      "id": "MB-R078",
      "title": "Strong TLS ciphers on upstream gateways",
      "control": "MB-C12",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "webserver_tls_ciphers",
          "args": {
            "files": [
              "nginx.conf",
              "pub/.htaccess",
              ".htaccess",
              "apache.conf"
            ],
            "require_protocols": true,
            "require_ciphers": true
          }
        }
      ],
      "messages": {
        "pass": "Web server enforces strong TLS protocols and cipher suites."
      }
    },
    {
      "id": "MB-R079",
      "title": "API keys stored in env.php (not in DB/plain code)",
      "control": "MB-C12",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_api_key_storage",
          "args": {
            "env_file": "app/etc/env.php",
            "paths": [
              "app/code",
              "app/etc",
              "app/design",
              "setup"
            ],
            "include_ext": [
              "php",
              "phtml",
              "xml",
              "sql"
            ],
            "max_results": 100
          }
        }
      ],
      "messages": {
        "pass": "API credentials are not embedded in code or written to database config paths."
      }
    },
    {
      "id": "MB-R080",
      "title": "Third-party logging sanitized (mask/redact)",
      "control": "MB-C12",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "code_third_party_logging_sanitized",
          "args": {
            "paths": [
              "app/code"
            ],
            "include_ext": [
              "php"
            ],
            "max_results": 100
          }
        }
      ],
      "messages": {
        "pass": "Third-party logs apply masking/redaction for sensitive fields."
      }
    },
    {
      "id": "MB-R081",
      "title": "SaaS integrations scoped by ACL (least privilege/IP allowlist)",
      "control": "MB-C12",
      "severity": "low",
      "op": "all",
      "checks": [
        {
          "name": "code_saas_integration_scoped",
          "args": {
            "paths": [
              "app/code",
              "app/etc"
            ],
            "include_ext": [
              "php",
              "xml"
            ],
            "max_results": 100
          }
        }
      ],
      "messages": {
        "pass": "SaaS integration entry points use least-privilege ACL resources or IP allowlists."
      }
    },
    {
      "id": "MB-R082",
      "title": "No PAN, CVV, or track data stored in database",
      "control": "MB-C12",
      "severity": "critical",
      "op": "all",
      "checks": [
        {
          "name": "code_cardholder_data_storage",
          "args": {
            "paths": [
              "app/code",
              "app/etc",
              "setup",
              "dev",
              "db"
            ],
            "include_ext": [
              "php",
              "xml",
              "sql",
              "json"
            ],
            "max_results": 100
          }
        }
      ],
      "messages": {
        "pass": "No database schema or code patterns indicating stored raw cardholder data were detected."
      }
    },
    {
      "id": "MB-R085",
      "title": "Payment method scope detection",
      "control": "MB-C12",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_payment_method_scope",
          "args": {
            "paths": [
              "app/code",
              "app/design"
            ],
            "include_ext": [
              "php",
              "phtml",
              "js",
              "xml"
            ],
            "max_results": 100
          }
        }
      ],
      "messages": {
        "pass": "No obvious direct raw-card payment scope patterns detected."
      }
    },
    {
      "id": "MB-R087",
      "title": "Payment page script inventory maintained",
      "control": "MB-C12",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_payment_script_inventory",
          "args": {
            "inventory_files": [
              ".magebean/payment-scripts.json",
              "docs/payment-script-inventory.md"
            ],
            "paths": [
              "app/design",
              "app/code"
            ],
            "include_ext": [
              "xml",
              "phtml",
              "html",
              "js"
            ],
            "max_results": 100
          }
        }
      ],
      "messages": {
        "pass": "Payment page script inventory is present, or no custom payment-page script sources were detected."
      }
    },
    {
      "id": "MB-R088",
      "title": "Payment page script allowlist and integrity controls",
      "control": "MB-C12",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_payment_script_integrity",
          "args": {
            "evidence_files": [
              ".magebean/payment-script-integrity.json"
            ],
            "paths": [
              "app/design",
              "app/code"
            ],
            "include_ext": [
              "xml",
              "phtml",
              "html",
              "js"
            ],
            "max_results": 100
          }
        }
      ],
      "messages": {
        "pass": "Payment page script allowlist or integrity controls are present, or no custom payment-page scripts were detected."
      }
    },
    {
      "id": "MB-R092",
      "title": "Payment webhook endpoint authentication hardening",
      "control": "MB-C12",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_webhook_signature_validation",
          "args": {
            "paths": [
              "app/code",
              "app/etc",
              "routes"
            ],
            "include_ext": [
              "php",
              "xml"
            ],
            "payment_only": true,
            "require_timestamp": true,
            "require_replay_window": true,
            "require_idempotency": true,
            "max_results": 100
          }
        }
      ],
      "messages": {
        "pass": "Payment webhook endpoints include signature validation, timestamp/replay protection, and idempotency evidence."
      }
    }
  ]
}
