{
  "control": "MB-C08",
  "title": "Cron Job Reliability",
  "rules": [
    {
      "id": "MB-R046",
      "title": "Crontab entries present (Magento cron)",
      "control": "MB-C08",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "cron_magento_configured",
          "args": {
            "users": [
              "www-data",
              "nginx",
              "apache",
              "http",
              "www",
              "magento",
              "deploy"
            ],
            "patterns": [
              "(?:^|\\s)(?:php\\s+[^\\n]*?)?bin/magento\\s+cron:run\\b",
              "(?:^|\\s)(?:php\\s+[^\\n]*?)?bin/magento\\s+setup:cron:run\\b",
              "(?:^|\\s)(?:php\\s+[^\\n]*?)?update/cron\\.php\\b"
            ],
            "repo_paths": [
              "deploy",
              ".github",
              ".gitlab-ci",
              ".circleci"
            ],
            "include_ext": [
              "sh",
              "bash",
              "txt",
              "md",
              "conf",
              "yml",
              "yaml",
              "ini",
              "env"
            ],
            "timeout_ms": 2500,
            "max_results": 20
          }
        }
      ],
      "messages": {
        "pass": "Found Magento cron run command in crontab or deployment scheduler configuration.",
        "fail": "No Magento cron entry found. Ensure 'bin/magento cron:run' runs every minute via crontab or scheduler."
      }
    },
    {
      "id": "MB-R047",
      "title": "Cron heartbeat is recent (<= 900s)",
      "control": "MB-C08",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "cron_heartbeat_recent",
          "args": {
            "files": [
              "var/cron/cron.timestamp",
              "var/log/cron.log",
              "var/log/magento.cron.log"
            ],
            "seconds": 900
          }
        }
      ],
      "messages": {
        "pass": "Cron heartbeat is recent (<= 15 minutes).",
        "fail": "Cron has not run in the last 15 minutes. Investigate cron service and schedule."
      }
    },
    {
      "id": "MB-R048",
      "title": "Cron backlog below threshold",
      "control": "MB-C08",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "cron_backlog_below_threshold",
          "args": {
            "files": [
              "var/cron/queue.size",
              "var/cron/backlog.json",
              "var/cron/backlog.txt"
            ],
            "max": 1000
          }
        }
      ],
      "messages": {
        "pass": "Cron queue size is within acceptable limits.",
        "fail": "Cron queue size is high. Jobs are backlogged—scale workers or fix failing jobs."
      }
    }
  ]
}
