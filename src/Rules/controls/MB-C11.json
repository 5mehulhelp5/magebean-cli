{
  "control": "MB-C11",
  "title": "Composer Dependency Hygiene",
  "rules": [
    {
      "id": "MB-R065",
      "title": "No wildcard constraints in composer.json",
      "control": "MB-C11",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "composer_json_constraints",
          "args": {
            "json_file": "composer.json",
            "sections": ["require", "require-dev"],
            "deny_wildcard": true,
            "finding_message": "Wildcard Composer constraints detected"
          }
        }
      ],
      "messages": {
        "pass": "No wildcard constraints found in composer.json."
      }
    },
    {
      "id": "MB-R066",
      "title": "No dev branches in composer.json",
      "control": "MB-C11",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "composer_json_constraints",
          "args": {
            "json_file": "composer.json",
            "sections": ["require", "require-dev"],
            "deny_dev_constraints": true,
            "finding_message": "Development Composer constraints detected"
          }
        }
      ],
      "messages": {
        "pass": "No development branch or dev-stability constraints are used."
      }
    },
    {
      "id": "MB-R067",
      "title": "prefer-stable=true in composer.json",
      "control": "MB-C11",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "composer_json_kv",
          "args": {
            "json_file": "composer.json",
            "key": "prefer-stable",
            "op": "eq",
            "expect": true,
            "strict": true
          }
        }
      ],
      "messages": {
        "pass": "composer.json sets top-level prefer-stable=true.",
        "fail": "prefer-stable is not enabled. Set top-level prefer-stable=true to favor stable releases."
      }
    },
    {
      "id": "MB-R068",
      "title": "Composer audit clean (no known vulns)",
      "control": "MB-C11",
      "severity": "critical",
      "op": "all",
      "checks": [
        {
          "name": "composer_audit_api",
          "args": {
            "lock_file": "composer.lock",
            "endpoint": "https://api.magebean.com/v1/osv/advisories",
            "timeout_ms": 10000,
            "batch_size": 500,
            "allow_private_http_fallback": true
          }
        }
      ],
      "messages": {
        "pass": "No known vulnerabilities found in composer.lock by the Magebean OSV API."
      }
    },
    {
      "id": "MB-R069",
      "title": "Direct dependencies up-to-date",
      "control": "MB-C11",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "composer_direct_outdated_api",
          "args": {
            "lock_file": "composer.lock",
            "json_file": "composer.json",
            "status_endpoint": "https://api.magebean.com/v1/packages/status",
            "timeout_ms": 10000,
            "status_batch_size": 500,
            "allow_private_http_fallback": true,
            "include_dev": true
          }
        }
      ],
      "messages": {
        "pass": "All assessable direct dependencies use the latest stable release."
      }
    },
    {
      "id": "MB-R070",
      "title": "composer.lock integrity with composer.json",
      "control": "MB-C11",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "composer_lock_integrity",
          "args": {
            "json_file": "composer.json",
            "lock_file": "composer.lock"
          }
        }
      ],
      "messages": {
        "pass": "composer.lock content-hash and direct dependency graph match composer.json."
      }
    },
    {
      "id": "MB-R071",
      "title": "No abandoned libraries allowed",
      "control": "MB-C11",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "composer_abandoned_api",
          "args": {
            "lock_file": "composer.lock",
            "status_endpoint": "https://api.magebean.com/v1/packages/status",
            "timeout_ms": 10000,
            "status_batch_size": 500,
            "allow_private_http_fallback": true,
            "package_types": ["library"]
          }
        }
      ],
      "messages": {
        "pass": "No installed PHP libraries are marked as abandoned on Packagist."
      }
    }
  ]
}
