{
  "control": "MB-C03",
  "title": "Secure Coding Practices",
  "rules": [
    {
      "id": "MB-R012",
      "title": "No raw SQL without abstraction",
      "control": "MB-C03",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_raw_sql",
          "args": {
            "paths": [
              "app"
            ],
            "include_ext": [
              "php",
              "phtml"
            ]
          }
        }
      ],
      "messages": {
        "pass": "No unsafe raw SQL statements detected; database queries use abstraction layers.",
        "fail": "Unsafe raw SQL calls detected (query, mysqli_query, or new PDO). Use Magento DB abstraction or safe ORM."
      }
    },
    {
      "id": "MB-R013",
      "title": "Template output is escaped",
      "control": "MB-C03",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_phtml_escaped_output",
          "args": {
            "paths": [
              "app"
            ],
            "escape_functions": [
              "escapeHtml",
              "escapeHtmlAttr",
              "escapeUrl",
              "escapeJs",
              "escapeCss"
            ]
          }
        }
      ],
      "messages": {
        "pass": "Template output uses proper escaping functions.",
        "fail": "Unescaped template output detected. Use escapeHtml() or escapeHtmlAttr() for safe rendering."
      }
    },
    {
      "id": "MB-R014",
      "title": "Avoid PHP superglobals directly",
      "control": "MB-C03",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_unserialize_safety",
          "args": {
            "paths": [
              "app"
            ],
            "include_ext": [
              "php"
            ],
            "must_not_match": [
              "\\$_(?:GET|POST|REQUEST|COOKIE|FILES|SERVER)\\b"
            ]
          }
        }
      ],
      "messages": {
        "pass": "No direct access to PHP superglobals detected.",
        "fail": "Direct use of PHP request superglobals found. Use Magento request, cookie, file upload, or server abstractions for sanitization."
      }
    },
    {
      "id": "MB-R015",
      "title": "Forms include CSRF tokens (form_key)",
      "control": "MB-C03",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_csrf_form_key",
          "args": {
            "paths": [
              "app"
            ]
          }
        }
      ],
      "messages": {
        "pass": "Forms include CSRF protection via form_key.",
        "fail": "Forms without form_key detected. Add CSRF token for protection."
      }
    },
    {
      "id": "MB-R016",
      "title": "SSRF protections present",
      "control": "MB-C03",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_ssrf_safeguards",
          "args": {
            "paths": [
              "app"
            ],
            "include_ext": [
              "php"
            ]
          }
        }
      ],
      "messages": {
        "pass": "Outbound HTTP requests include SSRF protections (allowlists and timeouts).",
        "fail": "No SSRF protections found. Add domain allowlists and connection timeouts."
      }
    },
    {
      "id": "MB-R017",
      "title": "No unsafe deserialization",
      "control": "MB-C03",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_grep",
          "args": {
            "paths": [
              "app"
            ],
            "include_ext": [
              "php"
            ]
          }
        }
      ],
      "messages": {
        "pass": "No unsafe unserialize() usage detected; safe serialization methods in use.",
        "fail": "Unsafe unserialize() calls detected. Replace with JSON or Magento Serializer classes."
      }
    },
    {
      "id": "MB-R018",
      "title": "Command execution is guarded",
      "control": "MB-C03",
      "severity": "critical",
      "op": "all",
      "checks": [
        {
          "name": "code_command_execution_safety",
          "args": {
            "paths": [
              "app"
            ],
            "include_ext": [
              "php"
            ]
          }
        }
      ],
      "messages": {
        "pass": "Command execution sinks are absent or guarded by escaping/allow-lists.",
        "fail": "Unsafe command execution detected. Avoid shell execution or enforce strict allow-lists and escaping."
      }
    },
    {
      "id": "MB-R019",
      "title": "No eval/assert/dynamic execution",
      "control": "MB-C03",
      "severity": "critical",
      "op": "all",
      "checks": [
        {
          "name": "code_dynamic_execution_safety",
          "args": {
            "paths": [
              "app"
            ],
            "include_ext": [
              "php"
            ]
          }
        }
      ],
      "messages": {
        "pass": "No unsafe dynamic execution patterns detected.",
        "fail": "Unsafe eval/assert/dynamic include/callable execution detected. Remove or refactor these patterns."
      }
    },
    {
      "id": "MB-R020",
      "title": "Path traversal protections",
      "control": "MB-C03",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_path_traversal_safety",
          "args": {
            "paths": [
              "app"
            ],
            "include_ext": [
              "php"
            ]
          }
        }
      ],
      "messages": {
        "pass": "File path sinks are absent or guarded against traversal.",
        "fail": "Potential path traversal sinks found. Normalize paths and enforce base-directory allow-lists."
      }
    },
    {
      "id": "MB-R021",
      "title": "Secure file upload handling",
      "control": "MB-C03",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_upload_safety",
          "args": {
            "paths": [
              "app"
            ],
            "include_ext": [
              "php"
            ]
          }
        }
      ],
      "messages": {
        "pass": "Upload flows are absent or include validation and storage safeguards.",
        "fail": "Potential unsafe upload flow. Validate MIME type, extension, size, and destination before storing files."
      }
    },
    {
      "id": "MB-R022",
      "title": "Escaping for JS context",
      "control": "MB-C03",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_js_context_escaping",
          "args": {
            "paths": [
              "app"
            ],
            "include_ext": [
              "phtml",
              "html"
            ]
          }
        }
      ],
      "messages": {
        "pass": "JavaScript-context PHP output is escaped or encoded.",
        "fail": "Unescaped PHP output found in JavaScript context. Use escapeJs(), escapeJsQuote(), or JSON encoding."
      }
    },
    {
      "id": "MB-R023",
      "title": "Use CSPRNG; avoid weak PRNG",
      "control": "MB-C03",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_csprng_safety",
          "args": {
            "paths": [
              "app"
            ],
            "include_ext": [
              "php"
            ]
          }
        }
      ],
      "messages": {
        "pass": "No weak PRNG detected in security-sensitive randomness.",
        "fail": "Weak PRNG used in security-sensitive context. Use random_int() or random_bytes()."
      }
    },
    {
      "id": "MB-R024",
      "title": "Sensitive data not logged",
      "control": "MB-C03",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_sensitive_logging",
          "args": {
            "paths": [
              "app"
            ],
            "include_ext": [
              "php"
            ]
          }
        }
      ],
      "messages": {
        "pass": "No raw sensitive data logging detected.",
        "fail": "Sensitive data logging detected. Redact passwords, tokens, authorization headers, cookies, and payment data before logging."
      }
    },
    {
      "id": "MB-R025",
      "title": "Use Magento APIs for crypto & session",
      "control": "MB-C03",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "code_magento_api_crypto_session",
          "args": {
            "paths": [
              "app"
            ],
            "include_ext": [
              "php"
            ]
          }
        }
      ],
      "messages": {
        "pass": "Magento crypto and session APIs are used.",
        "fail": "Raw crypto/session API usage found. Use Magento Framework Encryption, Cookie, and Session APIs instead."
      }
    },
    {
      "id": "MB-R086",
      "title": "No raw card collection in Magento checkout",
      "control": "MB-C03",
      "severity": "critical",
      "op": "all",
      "checks": [
        {
          "name": "code_grep",
          "args": {
            "paths": [
              "app",
              "app/design"
            ],
            "include_ext": [
              "php",
              "phtml",
              "js",
              "html",
              "xml"
            ],
            "must_not_match": [
              "(?i)\\b(?:card[_-]?number|cc[_-]?number|creditcard|credit_card|pan|primary.?account.?number|cvv|cvc|card[_-]?security[_-]?code|expiry|exp_month|exp_year)\\b",
              "(?i)<input[^>]+name\\s*=\\s*['\\\"][^'\\\"]*(?:card|cc|cvv|cvc)[^'\\\"]*['\\\"]"
            ],
            "max_results": 50
          }
        }
      ],
      "messages": {
        "pass": "No raw card collection patterns detected in custom checkout code.",
        "fail": "Raw card collection patterns detected. Use hosted payment fields, redirect flows, or tokenized provider SDKs."
      }
    },
    {
      "id": "MB-R094",
      "title": "Authorization checks on custom controllers and APIs",
      "control": "MB-C03",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_grep",
          "args": {
            "paths": [
              "app/code"
            ],
            "include_ext": [
              "php",
              "xml"
            ],
            "must_not_match": [
              "(?is)class\\s+\\w+.*?Controller.*?function\\s+execute\\s*\\([^)]*\\)\\s*\\{(?:(?!ADMIN_RESOURCE|_authorization|AuthorizationInterface|isAllowed|customerSession|isLoggedIn|getCustomerId).){0,1600}\\b(?:order|customer|invoice|shipment|creditmemo|download|export)\\b",
              "(?is)<route\\b[^>]*url\\s*=\\s*['\\\"][^'\\\"]*(?:order|customer|invoice|export|download)[^'\\\"]*['\\\"][^>]*>\\s*<service[^>]+resource\\s*=\\s*['\\\"]anonymous['\\\"]"
            ],
            "max_results": 50
          }
        }
      ],
      "messages": {
        "pass": "Custom controllers and APIs include authorization signals for sensitive workflows.",
        "fail": "Potential missing authorization checks in custom controllers or APIs. Add ACL, ownership, or session authorization checks."
      }
    },
    {
      "id": "MB-R095",
      "title": "GraphQL and API exposure minimized",
      "control": "MB-C03",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "code_grep",
          "args": {
            "paths": [
              "app/code",
              "app/etc"
            ],
            "include_ext": [
              "xml",
              "graphqls",
              "php"
            ],
            "must_not_match": [
              "(?is)<service[^>]+class\\s*=\\s*['\\\"][^'\\\"]*(?:Order|Customer|Payment|Invoice|Admin|Export)[^'\\\"]*['\\\"][^>]+resource\\s*=\\s*['\\\"]anonymous['\\\"]",
              "(?i)\\b(?:customer|order|invoice|payment|admin|export)\\w*\\s*:\\s*\\w+\\s*@resolver"
            ],
            "max_results": 50
          }
        },
        {
          "name": "http_graphql_introspection_disabled",
          "args": {
            "timeout_ms": 8000
          }
        }
      ],
      "messages": {
        "pass": "No high-risk anonymous API exposure or GraphQL introspection signals detected.",
        "fail": "Potentially excessive API or GraphQL exposure detected. Restrict anonymous access and disable production introspection."
      }
    },
    {
      "id": "MB-R097",
      "title": "Secrets are not hardcoded in custom code",
      "control": "MB-C03",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_grep",
          "args": {
            "paths": [
              "app",
              "app/design"
            ],
            "include_ext": [
              "php",
              "phtml",
              "js",
              "xml",
              "json",
              "env",
              "dist"
            ],
            "must_not_match": [
              "(?i)\\b(?:api[_-]?key|secret|token|private[_-]?key|password|client[_-]?secret)\\b\\s*[:=]\\s*['\\\"][A-Za-z0-9_\\-\\/.+=]{16,}['\\\"]",
              "-----BEGIN (?:RSA |EC |OPENSSH |)PRIVATE KEY-----"
            ],
            "max_results": 50
          }
        }
      ],
      "messages": {
        "pass": "No hardcoded secrets detected in custom code paths.",
        "fail": "Hardcoded secret patterns detected. Move secrets to env.php, environment variables, or a secret manager and rotate exposed values."
      }
    },
    {
      "id": "MB-R098",
      "title": "Unsafe XML parsing disabled",
      "control": "MB-C03",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_grep",
          "args": {
            "paths": [
              "app"
            ],
            "include_ext": [
              "php"
            ],
            "must_not_match": [
              "\\bLIBXML_(?:NOENT|DTDLOAD)\\b",
              "libxml_disable_entity_loader\\s*\\(\\s*false\\s*\\)",
              "simplexml_load_(?:string|file)\\s*\\([^;]*(?:LIBXML_NOENT|LIBXML_DTDLOAD)",
              "DOMDocument\\s*\\([^)]*\\)\\s*;[^\\n]{0,200}->\\s*loadXML\\s*\\([^;]*(?:LIBXML_NOENT|LIBXML_DTDLOAD)"
            ],
            "max_results": 50
          }
        }
      ],
      "messages": {
        "pass": "No unsafe XML entity expansion patterns detected.",
        "fail": "Unsafe XML parsing patterns detected. Disable external entity loading and avoid entity expansion for untrusted XML."
      }
    },
    {
      "id": "MB-R099",
      "title": "File download and export endpoints require authorization",
      "control": "MB-C03",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_grep",
          "args": {
            "paths": [
              "app/code"
            ],
            "include_ext": [
              "php",
              "xml"
            ],
            "must_not_match": [
              "(?is)class\\s+\\w+.*?Controller.*?function\\s+execute\\s*\\([^)]*\\)\\s*\\{(?:(?!ADMIN_RESOURCE|_authorization|AuthorizationInterface|isAllowed|customerSession|isLoggedIn|getCustomerId).){0,1600}\\b(?:FileFactory|create\\s*\\(|download|export|csv|pdf)\\b",
              "(?is)<route\\b[^>]*url\\s*=\\s*['\\\"][^'\\\"]*(?:download|export|invoice|report)[^'\\\"]*['\\\"][^>]*>\\s*<service[^>]+resource\\s*=\\s*['\\\"]anonymous['\\\"]"
            ],
            "max_results": 50
          }
        }
      ],
      "messages": {
        "pass": "No unprotected download or export endpoint patterns detected.",
        "fail": "Potential unprotected download/export endpoint detected. Add ACL, session, ownership, or signed URL validation."
      }
    }
  ]
}
