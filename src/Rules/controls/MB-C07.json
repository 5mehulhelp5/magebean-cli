{
  "control": "MB-C07",
  "title": "Logging & Monitoring",
  "rules": [
    {
      "id": "MB-R042",
      "title": "Logs and reports not exposed under pub/",
      "control": "MB-C07",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "fs_logs_reports_not_in_webroot",
          "args": {
            "webroot": "pub",
            "forbidden_paths": [
              "var/log",
              "var/report"
            ]
          }
        }
      ],
      "messages": {
        "pass": "Log and report directories are not exposed under pub/.",
        "fail": "Log or report directories are exposed in pub/. Move them out of the webroot."
      }
    },
    {
      "id": "MB-R043",
      "title": "Log rotation configured",
      "control": "MB-C07",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "fs_log_rotation_configured",
          "args": {
            "file": "devops/logrotate.conf"
          }
        }
      ],
      "messages": {
        "pass": "Log rotation is configured (rotate and compress directives present).",
        "fail": "Log rotation is not configured. Add logrotate settings to prevent oversized log files."
      }
    },
    {
      "id": "MB-R044",
      "title": "Debug template hints disabled in production",
      "control": "MB-C07",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "php_dev_debug_config_disabled",
          "args": {
            "file": "app/etc/env.php",
            "paths": [
              "system.default.dev/translate_inline/active",
              "system.default.dev/debug/template_hints_storefront"
            ]
          }
        }
      ],
      "messages": {
        "pass": "Debug template hints are disabled in production.",
        "fail": "Debug developer settings are enabled in production. Disable translate inline and template hints settings."
      }
    },
    {
      "id": "MB-R045",
      "title": "PII not logged in application logs",
      "control": "MB-C07",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_sensitive_logging",
          "args": {
            "paths": [
              "app"
            ],
            "include_ext": [
              "php"
            ],
            "max_results": 50
          }
        }
      ],
      "messages": {
        "pass": "No PII such as passwords, tokens, or card data is logged.",
        "fail": "Sensitive PII is logged. Remove logging of passwords, tokens, and card details."
      }
    },
    {
      "id": "MB-R084",
      "title": "No cardholder data in application logs",
      "control": "MB-C07",
      "severity": "critical",
      "op": "all",
      "checks": [
        {
          "name": "code_cardholder_data_logs",
          "args": {
            "paths": [
              "var/log",
              "var/report",
              "pub/media/log",
              "pub/media/report"
            ],
            "include_ext": [
              "log",
              "txt",
              "json",
              "xml"
            ],
            "max_results": 100
          }
        }
      ],
      "messages": {
        "pass": "No cardholder data patterns detected in application logs."
      }
    },
    {
      "id": "MB-R090",
      "title": "Payment page tamper monitoring readiness",
      "control": "MB-C07",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_payment_page_tamper_monitoring",
          "args": {
            "evidence_files": [
              ".magebean/payment-page-monitoring.json",
              "docs/payment-page-monitoring.md"
            ],
            "paths": [
              "app/code",
              "app/etc",
              "app/design",
              "pub/.htaccess",
              ".htaccess",
              "nginx.conf"
            ],
            "include_ext": [
              "xml",
              "php",
              "phtml",
              "js",
              "html",
              "conf",
              "htaccess"
            ]
          }
        }
      ],
      "messages": {
        "pass": "Payment page tamper monitoring includes payment-page scope, alerting, and CSP reporting or scheduled integrity detection."
      }
    },
    {
      "id": "MB-R093",
      "title": "PCI manual evidence checklist present",
      "control": "MB-C07",
      "severity": "low",
      "op": "all",
      "checks": [
        {
          "name": "pci_manual_evidence_documented",
          "args": {
            "paths": [
              ".magebean/pci-evidence.md",
              "docs/pci-evidence.md",
              "SECURITY.md"
            ],
            "required_topics": [
              "payment_scope",
              "saq_notes",
              "access_review",
              "incident_response",
              "vendor_responsibilities"
            ]
          }
        }
      ],
      "messages": {
        "pass": "PCI evidence documentation covers payment scope, SAQ notes, access review, incident response, and vendor responsibilities."
      }
    }
  ]
}
