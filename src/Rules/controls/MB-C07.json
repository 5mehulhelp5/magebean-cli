{
  "control": "MB-C07",
  "title": "Logging & Monitoring",
  "rules": [
    {
      "id": "MB-R042",
      "title": "Logs and reports not exposed under pub/",
      "control": "MB-C07",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "fs_logs_reports_not_in_webroot",
          "args": {
            "webroot": "pub",
            "forbidden_paths": [
              "var/log",
              "var/report"
            ]
          }
        }
      ],
      "messages": {
        "pass": "Log and report directories are not exposed under pub/.",
        "fail": "Log or report directories are exposed in pub/. Move them out of the webroot."
      }
    },
    {
      "id": "MB-R043",
      "title": "Log rotation configured",
      "control": "MB-C07",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "fs_log_rotation_configured",
          "args": {
            "file": "devops/logrotate.conf"
          }
        }
      ],
      "messages": {
        "pass": "Log rotation is configured (rotate and compress directives present).",
        "fail": "Log rotation is not configured. Add logrotate settings to prevent oversized log files."
      }
    },
    {
      "id": "MB-R044",
      "title": "Debug template hints disabled in production",
      "control": "MB-C07",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "php_dev_debug_config_disabled",
          "args": {
            "file": "app/etc/env.php",
            "paths": [
              "system.default.dev/translate_inline/active",
              "system.default.dev/debug/template_hints_storefront"
            ]
          }
        }
      ],
      "messages": {
        "pass": "Debug template hints are disabled in production.",
        "fail": "Debug developer settings are enabled in production. Disable translate inline and template hints settings."
      }
    },
    {
      "id": "MB-R045",
      "title": "PII not logged in application logs",
      "control": "MB-C07",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "code_sensitive_logging",
          "args": {
            "paths": [
              "app"
            ],
            "include_ext": [
              "php"
            ],
            "max_results": 50
          }
        }
      ],
      "messages": {
        "pass": "No PII such as passwords, tokens, or card data is logged.",
        "fail": "Sensitive PII is logged. Remove logging of passwords, tokens, and card details."
      }
    },
    {
      "id": "MB-R084",
      "title": "No cardholder data in application logs",
      "control": "MB-C07",
      "severity": "critical",
      "op": "all",
      "checks": [
        {
          "name": "code_cardholder_data_logs",
          "args": {
            "paths": [
              "var/log",
              "var/report",
              "pub/media/log",
              "pub/media/report"
            ],
            "include_ext": [
              "log",
              "txt",
              "json",
              "xml"
            ],
            "max_results": 100
          }
        }
      ],
      "messages": {
        "pass": "No cardholder data patterns detected in application logs."
      }
    },
    {
      "id": "MB-R090",
      "title": "Payment page tamper monitoring readiness",
      "control": "MB-C07",
      "severity": "high",
      "op": "any",
      "checks": [
        {
          "name": "fs_exists",
          "args": {
            "path": ".magebean/payment-page-monitoring.json"
          }
        },
        {
          "name": "fs_exists",
          "args": {
            "path": "docs/payment-page-monitoring.md"
          }
        },
        {
          "name": "code_grep",
          "args": {
            "paths": [
              "app",
              "app/etc",
              "app/design"
            ],
            "include_ext": [
              "xml",
              "php",
              "phtml",
              "js"
            ],
            "must_match": [
              "(?i)(report-uri|report-to|securitypolicyviolation|integrity=|sha256-|checksum|file.?integrity|tamper)"
            ],
            "max_results": 20
          }
        }
      ],
      "messages": {
        "pass": "Payment page tamper monitoring or reporting signals are present.",
        "fail": "No payment page tamper monitoring evidence found. Add CSP reporting, file integrity monitoring, or documented monitoring."
      }
    },
    {
      "id": "MB-R093",
      "title": "PCI manual evidence checklist present",
      "control": "MB-C07",
      "severity": "low",
      "op": "any",
      "checks": [
        {
          "name": "fs_exists",
          "args": {
            "path": ".magebean/pci-evidence.md"
          }
        },
        {
          "name": "fs_exists",
          "args": {
            "path": "docs/pci-evidence.md"
          }
        },
        {
          "name": "fs_exists",
          "args": {
            "path": "SECURITY.md"
          }
        }
      ],
      "messages": {
        "pass": "PCI evidence documentation is present.",
        "fail": "No PCI evidence checklist found. Add a project evidence file covering payment scope, SAQ notes, access review, incident response, and vendor responsibilities."
      }
    }
  ]
}
