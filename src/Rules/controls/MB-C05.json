{
  "control": "MB-C05",
  "title": "Production Mode & Deployment Hygiene",
  "rules": [
    {
      "id": "MB-R031",
      "title": "Magento runs in PRODUCTION mode",
      "control": "MB-C05",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "magento_production_mode",
          "args": {
            "file": "app/etc/env.php",
            "path": "MAGE_MODE",
            "equals": "production"
          }
        }
      ],
      "messages": {
        "pass": "Magento is running in PRODUCTION mode.",
        "fail": "Magento is not in PRODUCTION mode. Set MAGE_MODE to 'production' in env.php and redeploy."
      }
    },
    {
      "id": "MB-R032",
      "title": "Xdebug disabled in production",
      "control": "MB-C05",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "php_xdebug_disabled",
          "args": {
            "files": [
              "php.ini",
              ".user.ini"
            ]
          }
        },
        {
          "name": "http_no_xdebug_headers",
          "args": {
            "timeout_ms": 8000
          }
        }
      ],
      "messages": {
        "pass": "Xdebug is not enabled in the production PHP configuration.",
        "fail": "Xdebug settings detected. Remove the zend_extension and xdebug.* directives in production."
      }
    },
    {
      "id": "MB-R033",
      "title": "display_errors is Off",
      "control": "MB-C05",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "php_display_errors_disabled",
          "args": {
            "files": [
              "php.ini",
              ".user.ini"
            ]
          }
        },
        {
          "name": "http_no_stacktrace",
          "args": {
            "timeout_ms": 8000
          }
        }
      ],
      "messages": {
        "pass": "PHP display_errors is Off. No error traces visible.",
        "fail": "PHP display_errors is On. Set display_errors=Off and log errors to files instead or error/stack trace visible on pages."
      }
    },
    {
      "id": "MB-R034",
      "title": "Compiled DI generated (metadata & code)",
      "control": "MB-C05",
      "severity": "low",
      "op": "all",
      "checks": [
        {
          "name": "fs_di_compiled",
          "args": {
            "metadata_path": "generated/metadata",
            "code_path": "generated/code",
            "min_metadata_php_files": 1,
            "min_code_php_files": 1
          }
        }
      ],
      "messages": {
        "pass": "Generated DI metadata and code are present.",
        "fail": "Missing generated/metadata or generated/code. Run `bin/magento setup:di:compile`."
      }
    },
    {
      "id": "MB-R035",
      "title": "Static content deployed",
      "control": "MB-C05",
      "severity": "low",
      "op": "all",
      "checks": [
        {
          "name": "fs_static_content_deployed",
          "args": {
            "static_path": "pub/static",
            "preprocessed_path": "var/view_preprocessed",
            "min_static_files": 1,
            "min_preprocessed_files": 1
          }
        },
        {
          "name": "http_static_assets_deployed",
          "args": {
            "timeout_ms": 8000
          }
        }
      ],
      "messages": {
        "pass": "Static view files are deployed (pub/static and var/view_preprocessed exist).",
        "fail": "Static content is not fully deployed. Run `bin/magento setup:static-content:deploy` for production."
      }
    },
    {
      "id": "MB-R036",
      "title": "No dev debug configs on production (template hints off)",
      "control": "MB-C05",
      "severity": "medium",
      "op": "any",
      "checks": [
        {
          "name": "php_template_hints_disabled",
          "args": {
            "file": "app/etc/env.php",
            "paths": [
              "system.default.dev/debug/template_hints"
            ]
          }
        }
      ],
      "messages": {
        "pass": "Developer template hints are disabled in production.",
        "fail": "Developer template hints are enabled. Disable system.default.dev/debug/template_hints (set to 0)."
      }
    }
  ]
}
