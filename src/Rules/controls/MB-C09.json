{
  "control": "MB-C09",
  "title": "Extension Vulnerability Management",
  "rules": [
    {
      "id": "MB-R049",
      "title": "No vulnerable packages (CVE via OSV)",
      "control": "MB-C09",
      "severity": "critical",
      "op": "all",
      "checks": [
        {
          "name": "composer_audit_api",
          "args": {
            "lock_file": "composer.lock",
            "endpoint": "https://api.magebean.com/v1/osv/advisories",
            "timeout_ms": 10000,
            "batch_size": 500,
            "allow_private_http_fallback": true
          }
        }
      ],
      "messages": {
        "pass": "No vulnerable packages detected by the Magebean OSV API."
      }
    },
    {
      "id": "MB-R050",
      "title": "Adobe security patches applied",
      "control": "MB-C09",
      "severity": "critical",
      "op": "all",
      "checks": [
        {
          "name": "composer_adobe_security_patches_api",
          "args": {
            "lock_file": "composer.lock",
            "endpoint": "https://api.magebean.com/v1/adobe/security-patches",
            "timeout_ms": 10000,
            "allow_private_http_fallback": true
          }
        }
      ],
      "messages": {
        "pass": "All applicable Adobe security patch releases are applied."
      }
    },
    {
      "id": "MB-R051",
      "title": "Suggest fixed versions for vulnerable packages",
      "control": "MB-C09",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "composer_fix_version_api",
          "args": {
            "lock_file": "composer.lock",
            "endpoint": "https://api.magebean.com/v1/osv/advisories",
            "timeout_ms": 10000,
            "batch_size": 500,
            "allow_private_http_fallback": true
          }
        }
      ],
      "messages": {
        "pass": "No vulnerable packages require a fixed-version recommendation."
      }
    },
    {
      "id": "MB-R052",
      "title": "Enabled high-risk modules are maintained",
      "control": "MB-C09",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "composer_risk_surface_tag",
          "args": {
            "lock_file": "composer.lock",
            "status_endpoint": "https://api.magebean.com/v1/packages/status",
            "timeout_ms": 10000,
            "batch_size": 500,
            "allow_private_http_fallback": true
          }
        }
      ],
      "messages": {
        "pass": "Enabled high-risk modules are current, or detected high-risk modules are disabled."
      }
    },
    {
      "id": "MB-R053",
      "title": "Temporary mitigations documented",
      "control": "MB-C09",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "security_mitigations_documented",
          "args": {
            "path": "SECURITY.md"
          }
        }
      ],
      "messages": {
        "pass": "Temporary mitigations and their rollback/remediation lifecycle are documented."
      }
    },
    {
      "id": "MB-R054",
      "title": "Known-exploited packages prioritized (CISA KEV)",
      "control": "MB-C09",
      "severity": "critical",
      "op": "all",
      "checks": [
        {
          "name": "composer_kev_advisories_api",
          "args": {
            "lock_file": "composer.lock",
            "endpoint": "https://api.magebean.com/v1/osv/advisories",
            "timeout_ms": 10000,
            "batch_size": 500,
            "allow_private_http_fallback": true
          }
        }
      ],
      "messages": {
        "pass": "No installed package versions match the CISA Known Exploited Vulnerabilities catalog."
      }
    },
    {
      "id": "MB-R055",
      "title": "Transitive dependencies checked for CVEs",
      "control": "MB-C09",
      "severity": "critical",
      "op": "all",
      "checks": [
        {
          "name": "composer_transitive_audit_api",
          "args": {
            "lock_file": "composer.lock",
            "composer_file": "composer.json",
            "endpoint": "https://api.magebean.com/v1/osv/advisories",
            "timeout_ms": 10000,
            "batch_size": 500,
            "allow_private_http_fallback": true
          }
        }
      ],
      "messages": {
        "pass": "Transitive dependencies are free from known vulnerabilities."
      }
    },
    {
      "id": "MB-R056",
      "title": "No constraints blocking security updates",
      "control": "MB-C09",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "composer_constraints_conflict_api",
          "args": {
            "json_file": "composer.json",
            "lock_file": "composer.lock",
            "endpoint": "https://api.magebean.com/v1/osv/advisories",
            "timeout_ms": 10000,
            "batch_size": 500,
            "allow_private_http_fallback": true
          }
        }
      ],
      "messages": {
        "pass": "Composer constraints allow all required security update ranges."
      }
    },
    {
      "id": "MB-R057",
      "title": "No yanked/withdrawn packages",
      "control": "MB-C09",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "composer_yanked_api",
          "args": {
            "lock_file": "composer.lock",
            "status_endpoint": "https://api.magebean.com/v1/packages/status",
            "timeout_ms": 10000,
            "batch_size": 500,
            "allow_private_http_fallback": true
          }
        }
      ],
      "messages": {
        "pass": "No yanked or withdrawn package versions are installed."
      }
    },
    {
      "id": "MB-R058",
      "title": "Marketplace extensions are current and maintained",
      "control": "MB-C09",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "composer_marketplace_outdated_api",
          "args": {
            "lock_file": "composer.lock",
            "status_endpoint": "https://api.magebean.com/v1/packages/status",
            "timeout_ms": 10000,
            "batch_size": 500,
            "allow_private_http_fallback": true,
            "max_age_days": 365
          }
        }
      ],
      "messages": {
        "pass": "Marketplace and third-party Magento extensions are current and actively maintained."
      }
    },
    {
      "id": "MB-R059",
      "title": "Unresolved advisories are within remediation SLA",
      "control": "MB-C09",
      "severity": "low",
      "op": "all",
      "checks": [
        {
          "name": "composer_advisory_latency_api",
          "args": {
            "lock_file": "composer.lock",
            "endpoint": "https://api.magebean.com/v1/osv/advisories",
            "timeout_ms": 10000,
            "batch_size": 500,
            "allow_private_http_fallback": true,
            "latency_days": 30
          }
        }
      ],
      "messages": {
        "pass": "Installed packages have no overdue unresolved advisories."
      }
    },
    {
      "id": "MB-R060",
      "title": "Marketplace extensions have vendor support evidence",
      "control": "MB-C09",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "composer_vendor_support_api",
          "args": {
            "lock_file": "composer.lock",
            "status_endpoint": "https://api.magebean.com/v1/packages/status",
            "timeout_ms": 10000,
            "batch_size": 500,
            "allow_private_http_fallback": true
          }
        }
      ],
      "messages": {
        "pass": "Installed Marketplace extensions have active vendor support evidence."
      }
    }
  ]
}
